[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = false

[libraries]
macos.debug = "target/debug/libfeagi_agent_client.dylib"
macos.release = "target/release/libfeagi_agent_client.dylib"
windows.debug.x86_64 = "target/x86_64-pc-windows-msvc/debug/feagi_agent_client.dll"
windows.release.x86_64 = "target/x86_64-pc-windows-msvc/release/feagi_agent_client.dll"
linux.debug.x86_64 = "target/x86_64-unknown-linux-gnu/debug/libfeagi_agent_client.so"
linux.release.x86_64 = "target/x86_64-unknown-linux-gnu/release/libfeagi_agent_client.so"
linux.release.arm64 = "target/aarch64-unknown-linux-gnu/release/libfeagi_agent_client.so"
