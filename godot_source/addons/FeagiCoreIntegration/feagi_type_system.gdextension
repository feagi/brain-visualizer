[configuration]

entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]

macos.debug = "libfeagi_type_system.dylib"
macos.release = "libfeagi_type_system.dylib"
windows.debug.x86_64 = "feagi_type_system.dll"
windows.release.x86_64 = "feagi_type_system.dll"
linux.debug.x86_64 = "libfeagi_type_system.so"
linux.release.x86_64 = "libfeagi_type_system.so"

