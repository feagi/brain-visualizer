[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = false

[libraries]
macos.debug = "target/debug/libfeagi_shared_video.dylib"
macos.release = "target/release/libfeagi_shared_video.dylib"
windows.debug.x86_64 = "target/x86_64-pc-windows-msvc/debug/feagi_shared_video.dll"
windows.release.x86_64 = "target/x86_64-pc-windows-msvc/release/feagi_shared_video.dll"
linux.debug.x86_64 = "target/x86_64-unknown-linux-gnu/debug/libfeagi_shared_video.so"
linux.release.x86_64 = "target/x86_64-unknown-linux-gnu/release/libfeagi_shared_video.so"

[dependencies]

macos.debug = {
    "target/debug/libfeagi_shared_video.dylib": ""
}
macos.release = {
    "target/release/libfeagi_shared_video.dylib": ""
}
windows.debug.x86_64 = {
    "target/x86_64-pc-windows-msvc/debug/feagi_shared_video.dll": ""
}
windows.release.x86_64 = {
    "target/x86_64-pc-windows-msvc/release/feagi_shared_video.dll": ""
}
linux.debug.x86_64 = {
    "target/x86_64-unknown-linux-gnu/debug/libfeagi_shared_video.so": ""
}
linux.release.x86_64 = {
    "target/x86_64-unknown-linux-gnu/release/libfeagi_shared_video.so": ""
}


