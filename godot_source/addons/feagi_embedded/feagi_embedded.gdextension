[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = false

[libraries]
macos.debug = "libfeagi_embedded.dylib"
macos.release = "libfeagi_embedded.dylib"
windows.debug.x86_64 = "feagi_embedded.dll"
windows.release.x86_64 = "feagi_embedded.dll"
linux.debug.x86_64 = "libfeagi_embedded.so"
linux.release.x86_64 = "libfeagi_embedded.so"
